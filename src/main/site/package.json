    "test:shaders": "vitest run shaders",
    "lint:shaders": "node scripts/lint-shaders.mjs"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "sql.js": "^1.11.0",
    "three": "^0.183.0",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.5",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.3.3",
    "@types/sql.js": "^1.4.9",
    "@types/three": "^0.183.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "gh-pages": "^6.2.0",
    "glslx": "^0.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.0"
  }
}
